{% comment %}
  Grid of product cards. Pulls products from a chosen collection
  (falls back to all products) and renders the product-card snippet.
{% endcomment %}

<script src="{{ 'variant-swatches.js' | asset_url }}" defer></script>

<div class="mx-auto max-w-300 px-6 py-12">
  {%- if section.settings.heading != blank -%}
    <h2 class="mb-8 text-2xl font-medium text-ink">{{ section.settings.heading }}</h2>
  {%- endif -%}

  {%- liquid
    assign products = section.settings.collection.products
    if products == blank
      assign products = collections.all.products
    endif
  -%}

  <ul class="flex flex-wrap gap-10" role="list">
    {%- for product in products limit: section.settings.limit -%}
      <li class="min-w-0 max-w-full">
        {% render 'product-card', product: product, suffix: section.id %}
      </li>
    {%- else -%}
      <li class="text-ink">No products found. Add products to the store or pick another collection.</li>
    {%- endfor -%}
  </ul>
</div>

{% schema %}
{
  "name": "Product card grid",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Maximum products",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Product card grid"
    }
  ]
}
{% endschema %}
